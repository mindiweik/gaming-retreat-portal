# Neon Postgres (pooled connection string)
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"

# Discord OAuth — create these when we walk through Discord setup
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""
DISCORD_REDIRECT_URI="http://localhost:3000/api/auth/callback"

# Comma-separated Discord user IDs promoted to ADMIN on login
ADMIN_DISCORD_IDS=""

# Generate with: openssl rand -base64 32
SESSION_SECRET=""

# Public app origin (no trailing slash)
APP_URL="http://localhost:3000"

# Optional local-only shortcut. /api/auth/dev is disabled in production.
DEV_AUTO_LOGIN_DISCORD_ID=""

# Added later for waitlist notifications / cron
DISCORD_WEBHOOK_URL=""
CRON_SECRET=""
